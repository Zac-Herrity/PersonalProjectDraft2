<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="1000" MinHeight="500" MinWidth="800" ResizeMode="CanResize" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <Grid>
        <TabControl TabStripPlacement="Top" Name="MainTabControl">
            <TabItem Header="Home">
                <Grid Background="#0F172A">
                    <TextBlock x:Name="title" Text="Scene It" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,50,0,0" 
                               FontFamily="Bell MT" FontSize="60" FontWeight="Bold" FontStyle="Italic" Foreground="#F8E7B9"></TextBlock>
                    <TextBlock x:Name="chooseWhere" Text="Choose where to go!" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,130,0,0" FontFamily="Bell MT"
                               FontSize="24" Foreground="White"></TextBlock>
                    <Button x:Name="homeBtnList" Content="List Of Movies" Width="220" Height="55" FontSize="24" FontFamily="Bell MT" Background="#D4A017"
                            Margin="0,210,0,0" Foreground="Black" Click="homeBtnList_Click" HorizontalAlignment="Center" VerticalAlignment="Top"></Button>
                    <Button x:Name="homeBtnSeen" Content="Seen Movies" Width="220" Height="55" HorizontalAlignment="Center" VerticalAlignment="Top"
                            Margin="0,280,0,0" FontFamily="Bell MT" FontSize="24" Background="#D4A017" Foreground="Black" Click="homeBtnSeen_Click"></Button>
                    <Button x:Name="homeBtnRandom" Content="Surprise Me!" Width="220" Height="55" HorizontalAlignment="Center" VerticalAlignment="Top"
                            Margin="0,350,0,0" FontFamily="Bell MT" FontSize="24" Background="#D4A017" Foreground="Black" Click="homeBtnRandom_Click"></Button>
                    <Button x:Name="logoutBtn" Content="Logout" Width="120" Height="40" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,70" FontFamily="Bell MT" FontSize="20" Background="#1E293B" Foreground="White" BorderBrush="#D4A017"
                            BorderThickness="2" Click="logoutBtn_Click"></Button>
                </Grid>
            </TabItem>
            <TabItem Header="List Of Movies">
                <Grid Background="#0F172A">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Margin="0,0,20,15" VerticalAlignment="Top">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock x:Name="genreBlock" Text="Genre" Foreground="White" FontFamily="Bell MT" FontSize="20" Margin="0,0,0,6"></TextBlock>
                            <ComboBox x:Name="genreCombo" Width="130" Height="30" Background="#1E293B" Foreground="White" BorderBrush="#D4A017" SelectionChanged="genreCombo_SelectionChanged"></ComboBox>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock x:Name="sortByBlock" Text="Sort By" Foreground="White" FontFamily="Bell MT" FontSize="20" Margin="0,0,0,6"></TextBlock>
                            <ComboBox x:Name="sortByCombo" Width="130" Height="30" Background="#1E293B" Foreground="White" BorderBrush="#D4A017" SelectionChanged="sortByCombo_SelectionChanged"></ComboBox>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock x:Name="ratingText" Text="1-5*" Foreground="White" FontFamily="Bell MT" FontSize="20" TextAlignment="Center" Margin="0,0,0,6"></TextBlock>
                            <ComboBox x:Name="ratingCombo" Width="100" Height="30" Background="#1E293B" Foreground="White" BorderBrush="#D4A017"></ComboBox>
                        </StackPanel>
                        <Button x:Name="seenItBtn" Content="Scene It!" Width="100" Height="50" Margin="25,28,0,0" FontFamily="Bell MT" FontSize="20"
                                Background="#D4A017" Foreground="Black" Click="seenItBtn_Click"></Button>
                    </StackPanel>
                    <ListBox x:Name="movieListBox" Grid.Row="1" Grid.Column="0" Margin="0,0,20,0" Background="#1E293B" Foreground="White" BorderBrush="#D4A017" BorderThickness="2"
                             FontSize="16" SelectionChanged="movieListBox_SelectionChanged" d:ItemsSource="{d:SampleData}"></ListBox>
                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Background="#162033" BorderBrush="#D4A017" BorderThickness="2" CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Button x:Name="exit1" Content="X" Width="35" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" FontSize="16"
                                    Background="#D4A017" Foreground="Black" Click="exit1_Click"></Button>
                            <TextBlock x:Name="movieTitle1" TextWrapping="Wrap" Grid.Row="0" Margin="0,40,0,15" TextAlignment="Center" Foreground="#F8E7B9"
                                       FontFamily="Bell MT" FontSize="28" FontWeight="Bold"></TextBlock>
                            <Image x:Name="poster1" Grid.Row="1" Width="170" Height="170" Stretch="UniformToFill" Margin="0,0,0,20"></Image>
                            <TextBox x:Name="movieDetails1" Grid.Row="2" TextWrapping="Wrap" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                     Background="#1E293B" Foreground="White" BorderBrush="#D4A017" BorderThickness="2" FontFamily="Bell MT"
                                     FontSize="15"></TextBox>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem >
                <Grid>
                    <Image x:Name="moviePoster2" Source="https://cdn.pixabay.com/photo/2016/08/08/09/17/avatar-1577909_1280.png" HorizontalAlignment="Left" Height="150" Margin="588,72,0,0" VerticalAlignment="Top" Width="150"/>
                    <TextBlock x:Name="movieTitle2" HorizontalAlignment="Left" Margin="537,20,0,0" TextWrapping="Wrap" Text="Title" VerticalAlignment="Top" FontFamily="Bell MT" FontSize="24" Width="247" TextAlignment="Center"/>
                    <TextBox x:Name="movieDetails2" HorizontalAlignment="Left" Margin="537,236,0,0" TextWrapping="Wrap" Text="movie details here" VerticalAlignment="Top" Width="253" Height="137" FontFamily="Bell MT" FontSize="18"/>
                    <ComboBox x:Name="ratingCombo2" HorizontalAlignment="Center" Margin="0,236,0,0" VerticalAlignment="Top" Width="120" FontFamily="Bell MT" SelectionChanged="ratingCombo2_SelectionChanged"/>
                    <TextBlock x:Name="ratingText2" HorizontalAlignment="Center" TextWrapping="Wrap" Text="Change Review" TextAlignment="Center" VerticalAlignment="Top" Height="43" Width="120" FontFamily="Bell MT" FontSize="20" Margin="0,178,0,0"/>
                    <ListBox x:Name="seenMoviesList" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="22,118,476,61" SelectionChanged="seenMoviesList_SelectionChanged"/>
                    <TextBlock x:Name="seenMoviesText" HorizontalAlignment="Left" Margin="80,55,0,0" TextWrapping="Wrap" Text="Seen Movies" VerticalAlignment="Top" FontFamily="Bell MT" FontSize="36"/>
                    <Button x:Name="exit2" Content="X" HorizontalAlignment="Left" Margin="753,-1,0,0" VerticalAlignment="Top" Height="21" Width="31" FontSize="16" Click="exit2_Click"/>

                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
