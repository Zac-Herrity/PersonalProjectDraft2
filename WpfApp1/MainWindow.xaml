<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="1000" MinHeight="500" MinWidth="800" ResizeMode="CanResize" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <Grid>
        <TabControl TabStripPlacement="Top" Name="MainTabControl">
            <TabItem>
                <Grid Background="#0F172A">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="51*"/>
                        <ColumnDefinition Width="446*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="title" Text="Scene It" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="287,50,0,0" 
                               FontFamily="Bell MT" FontSize="60" FontWeight="Bold" FontStyle="Italic" Foreground="#F8E7B9" Grid.Column="1"></TextBlock>
                    <TextBlock x:Name="chooseWhere" Text="Choose where to go!" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="285,130,0,0" FontFamily="Bell MT"
                               FontSize="24" Foreground="White" Grid.Column="1"></TextBlock>
                    <Button x:Name="homeBtnList" Content="List Of Movies" Width="220" Height="55" FontSize="24" FontFamily="Bell MT" Background="#D4A017"
                            Margin="285,210,0,0" Foreground="Black" Click="homeBtnList_Click" HorizontalAlignment="Left" VerticalAlignment="Top" Grid.Column="1"></Button>
                    <Button x:Name="homeBtnSeen" Content="Seen Movies" Width="220" Height="55" HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="285,280,0,0" FontFamily="Bell MT" FontSize="24" Background="#D4A017" Foreground="Black" Click="homeBtnSeen_Click" Grid.Column="1"></Button>
                    <Button x:Name="homeBtnRandom" Content="Surprise Me!" Width="220" Height="55" HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="285,350,0,0" FontFamily="Bell MT" FontSize="24" Background="#D4A017" Foreground="Black" Click="homeBtnRandom_Click" Grid.Column="1"></Button>
                    <Button x:Name="logoutBtn" Content="Logout" Width="120" Height="40" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="335,0,0,70" FontFamily="Bell MT" FontSize="20" Background="#1E293B" Foreground="White" BorderBrush="#D4A017"
                            BorderThickness="2" Click="logoutBtn_Click" Grid.Column="1"></Button>
                </Grid>
            </TabItem>
            <TabItem>
                <Grid Background="#0F172A">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Margin="0,0,20,15" VerticalAlignment="Top">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock x:Name="genreBlock" Text="Genre" Foreground="White" FontFamily="Bell MT" FontSize="20" Margin="0,0,0,6"></TextBlock>
                            <ComboBox x:Name="genreCombo" Width="130" Height="30" Background="#1E293B" Foreground="#1E293B" FontWeight="Bold" BorderBrush="#D4A017" SelectionChanged="genreCombo_SelectionChanged">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#1E293B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock x:Name="sortByBlock" Text="Sort By" Foreground="White" FontFamily="Bell MT" FontSize="20" Margin="0,0,0,6"></TextBlock>
                            <ComboBox x:Name="sortByCombo" Width="130" Height="30" Background="#1E293B" Foreground="#1E293B" FontWeight="Bold" BorderBrush="#D4A017" SelectionChanged="sortByCombo_SelectionChanged">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#1E293B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock x:Name="ratingText" Text="1-5*" Foreground="White" FontFamily="Bell MT" FontSize="20" TextAlignment="Center" Margin="0,0,0,6"></TextBlock>
                            <ComboBox x:Name="ratingCombo" Width="100" Height="30" Background="#1E293B" Foreground="#1E293B" FontWeight="Bold" BorderBrush="#D4A017">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#1E293B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>
                        <Button x:Name="seenItBtn" Content="Scene It!" Width="100" Height="50" Margin="25,28,0,0" FontFamily="Bell MT" FontSize="20"
                                Background="#D4A017" Foreground="Black" Click="seenItBtn_Click"></Button>
                    </StackPanel>
                    <ListBox x:Name="movieListBox" Grid.Row="1" Grid.Column="0" Margin="0,0,20,0" Background="#1E293B" Foreground="White" BorderBrush="#D4A017" BorderThickness="2"
                             FontSize="16" SelectionChanged="movieListBox_SelectionChanged" d:ItemsSource="{d:SampleData}"></ListBox>
                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Background="#162033" BorderBrush="#D4A017" BorderThickness="2" CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Button x:Name="exit1" Content="X" Width="35" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" FontSize="16"
                                    Background="#D4A017" Foreground="Black" Click="exit1_Click"></Button>
                            <TextBlock x:Name="movieTitle1" TextWrapping="Wrap" HorizontalAlignment="Stretch" Grid.Row="0" Margin="0,40,0,15" TextAlignment="Center" Foreground="#F8E7B9"
                                       FontFamily="Bell MT" FontSize="28" FontWeight="Bold"></TextBlock>
                            <Image x:Name="poster1" Grid.Row="1" Width="170" Height="170" Stretch="UniformToFill" Margin="0,0,0,20"></Image>
                            <TextBox x:Name="movieDetails1" Grid.Row="2" TextWrapping="Wrap" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                     Background="#1E293B" Foreground="White" BorderBrush="#D4A017" BorderThickness="2" FontFamily="Bell MT"
                                     FontSize="15"></TextBox>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem>
                <Grid Background="#0F172A">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.2*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="seenMoviesText" Text="Seen Movies" Grid.Row="0" Grid.Column="0" Margin="10,0,0,10" Foreground="#F8E7B9"
                               FontFamily="Bell MT" FontSize="40"></TextBlock>
                    <ListBox x:Name="seenMoviesList" Grid.Row="1" Grid.Column="0" Margin="0,0,20,0" Background="#1E293B" Foreground="White" BorderBrush="#D4A017"
                             BorderThickness="2" FontSize="16" SelectionChanged="seenMoviesList_SelectionChanged"></ListBox>
                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Background="#162033" BorderBrush="#D4A017" BorderThickness="2" CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Button x:Name="exit2" Content="X" Width="35" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" FontSize="16"
                                    Background="#D4A017" Foreground="Black" Click="exit2_Click"></Button>
                            <TextBlock x:Name="movieTitle2" Grid.Row="0" Margin="0,40,0,15" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Stretch"
                                       Foreground="#F8E7B9" FontFamily="Bell MT" FontSize="26" FontWeight="Bold"></TextBlock>
                            <Image x:Name="moviePoster2" Grid.Row="1" Width="170" Height="170" Stretch="UniformToFill" Margin="0,0,0,20"></Image>
                            <TextBlock x:Name="ratingText2" Grid.Row="2" Text="Change Review" Foreground="White" FontFamily="Bell MT" FontSize="20"
                                       TextAlignment="Center" Margin="0,5,0,5"></TextBlock>
                            <ComboBox x:Name="ratingCombo2" Grid.Row="2" Width="120" Height="30" HorizontalAlignment="Center" Background="#1E293B" Foreground="#1E293B" FontWeight="Bold" 
                                      BorderBrush="#D4A017" SelectionChanged="ratingCombo2_SelectionChanged" Margin="0,40,0,5">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#1E293B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                            <TextBox x:Name="movieDetails2" Grid.Row="3" TextWrapping="Wrap" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                     Background="#1E293B" Foreground="White" BorderBrush="#D4A017" BorderThickness="2" FontFamily="Bell MT"
                                     FontSize="20"></TextBox>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
